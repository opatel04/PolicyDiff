# PolicyDiff Frontend — Environment Variables
# Copy this file to .env.local and fill in your values before running npm run dev
# NEVER commit .env.local to git

# ── Auth0 (v4 SDK) ────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000
# Domain only — no https:// prefix or trailing slash
AUTH0_DOMAIN=<your-auth0-domain>
AUTH0_CLIENT_ID=<your-auth0-client-id>
# Get from Auth0 dashboard → Applications → PolicyDiff → Settings → Client Secret
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=<your-auth0-api-audience>

# ── API ───────────────────────────────────────────────────────────────────────
# Backend API Gateway URL (from cdk deploy output)
NEXT_PUBLIC_API_URL=
