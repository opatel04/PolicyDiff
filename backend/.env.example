# PolicyDiff Backend — Environment Variables
# Copy this file to .env and fill in your values before running cdk synth / cdk deploy
# NEVER commit .env to git

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# CDK_DEFAULT_ACCOUNT is optional — CDK will use the account from your AWS CLI profile if not set
CDK_DEFAULT_ACCOUNT=

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Your Auth0 tenant domain (e.g. policydiff.us.auth0.com)
AUTH0_DOMAIN=
# API audience registered in Auth0 (e.g. https://api.policydiff.com)
AUTH0_AUDIENCE=
# Auth0 SPA client ID for the React frontend
AUTH0_CLIENT_ID=

# ── Bedrock ───────────────────────────────────────────────────────────────────
# Bedrock foundation model ARN for Claude Sonnet
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-sonnet-4-5
# Bedrock Titan Embeddings model ARN for S3 Vectors indexing
TITAN_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.titan-embed-text-v2:0
# S3 Vectors bucket name (auto-constructed from account/region in CDK, but useful for local testing)
VECTORS_BUCKET_NAME=
